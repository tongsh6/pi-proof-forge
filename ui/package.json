{
  "name": "piproofforge-gui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare:python-runtime": "python3 ./scripts/stage_python_runtime.py",
    "tauri": "pnpm run prepare:python-runtime && tauri",
    "smoke:app": "pnpm run tauri build --bundles app && python3 ./scripts/verify_packaged_app.py",
    "e2e:overview": "node ./scripts/verify_overview_native.mjs",
    "e2e:evidence": "node ./scripts/verify_evidence_native.mjs",
    "e2e:quick-run": "node ./scripts/verify_quick_run_native.mjs",
    "e2e:quick-run:webdriver": "node ./scripts/verify_quick_run_webdriver.mjs",
    "e2e:resumes": "node ./scripts/verify_resumes_native.mjs",
    "e2e:jobs": "node ./scripts/verify_jobs_native.mjs",
    "e2e:agent-run": "node ./scripts/verify_agent_run_native.mjs",
    "e2e:submissions": "node ./scripts/verify_submissions_native.mjs",
    "e2e:system-settings": "node ./scripts/verify_system_settings_native.mjs",
    "e2e:policy": "node ./scripts/verify_policy_native.mjs"
  },
  "dependencies": {
    "i18next": "^24.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/cli": "2.10.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
